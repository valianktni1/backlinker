# LinkBuilder Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Security
# ===========================================
# Generate a secure random string for JWT tokens
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# ===========================================
# REQUIRED - External Access
# ===========================================
# The external URL where your app will be accessible
# Example: http://192.168.1.100:8080 or https://linkbuilder.yourdomain.com
EXTERNAL_URL=http://localhost:8080

# Port to expose (default: 8080)
PORT=8080

# ===========================================
# OPTIONAL - SerpAPI (Google Search)
# ===========================================
# Get free API key at: https://serpapi.com (100 searches/month free)
# Without this, app falls back to DuckDuckGo + proxy rotation
SERPAPI_API_KEY=

# ===========================================
# OPTIONAL - SendGrid (Email Outreach)
# ===========================================
# Get free API key at: https://sendgrid.com (100 emails/day free)
# Without this, email outreach is disabled
SENDGRID_API_KEY=
SENDER_EMAIL=
